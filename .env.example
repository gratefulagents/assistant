# Copy to .env for local shells that load environment files.
# Do not commit real secrets.

ASSISTANT_PROVIDER=openai-oauth
ASSISTANT_MODEL=
ASSISTANT_WORKDIR=
ASSISTANT_PERMISSION=workspace-write
ASSISTANT_APPROVAL=true
ASSISTANT_TOOLS=true
ASSISTANT_MCP=false
ASSISTANT_SKILLS=false
ASSISTANT_SCHEDULING=true
ASSISTANT_PROJECT_STATE=true

# OPENAI_API_KEY=sk-...

# Telegram polling. Create a bot with @BotFather and paste its token here.
# ASSISTANT_TELEGRAM_BOT_TOKEN=123456:bot-token
# ASSISTANT_TELEGRAM_POLL_TIMEOUT=50

# ASSISTANT_GMAIL_ACCESS_TOKEN=oauth-access-token
# ASSISTANT_GATEWAY_TOKEN=long-random-token
