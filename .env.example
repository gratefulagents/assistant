# Copy to .env for local shells that load environment files.
# Do not commit real secrets.

ASSISTANT_PROVIDER=openai-oauth
ASSISTANT_MODEL=
# Set false for long-running assistant processes that share one Codex OAuth
# auth.json; refresh the file separately with `assistant oauth-refresh`.
ASSISTANT_OPENAI_OAUTH_REFRESH=true
# assistant oauth-refresh repeats on this interval by default; set 0 for once.
ASSISTANT_OPENAI_OAUTH_REFRESH_INTERVAL=1h
ASSISTANT_WORKDIR=
ASSISTANT_PERMISSION=workspace-write
ASSISTANT_APPROVAL=true
# user = terminal/Telegram approval only; auto-review = model reviewer first,
# escalating to terminal/Telegram only when the reviewer requires it.
ASSISTANT_APPROVALS_REVIEWER=user
# ASSISTANT_APPROVALS_REVIEWER_MODEL=
ASSISTANT_APPROVALS_REVIEWER_TIMEOUT=90
ASSISTANT_TOOLS=true
ASSISTANT_MCP=false
ASSISTANT_SKILLS=false
ASSISTANT_SCHEDULING=true
ASSISTANT_PROJECT_STATE=true
# Hybrid memory recall. Set a model to enable embeddings-backed semantic recall;
# leave empty for lexical-only. Base URL and key fall back to the OpenAI ones.
# ASSISTANT_EMBEDDING_MODEL=text-embedding-3-small
# ASSISTANT_EMBEDDING_BASE_URL=http://localhost:11434/v1
# ASSISTANT_EMBEDDING_API_KEY=sk-...
# ASSISTANT_EMBEDDING_DIMENSIONS=0
ASSISTANT_AUDIT=false
ASSISTANT_AUDIT_LEVEL=full
# ASSISTANT_AUDIT_LOG=~/.gratefulagents/assistant/state/audit.ndjson

# OPENAI_API_KEY=sk-...

# OpenRouter provider. Use with ASSISTANT_PROVIDER=openrouter and a model slug
# such as openai/gpt-4o-mini.
# OPENROUTER_API_KEY=sk-or-...

# Telegram polling. Create a bot with @BotFather and paste its token here.
# ASSISTANT_TELEGRAM_BOT_TOKEN=123456:bot-token
# Allow only these Telegram numeric user IDs, usernames, or chat IDs.
# Prefer numeric user IDs; with this unset, Telegram messages are ignored.
# ASSISTANT_TELEGRAM_ALLOWED_USERS=123456789
# ASSISTANT_TELEGRAM_ALLOWED_CHATS=-1001234567890
# ASSISTANT_TELEGRAM_POLL_TIMEOUT=50

# ASSISTANT_GMAIL_ACCESS_TOKEN=oauth-access-token
# ASSISTANT_GATEWAY_TOKEN=long-random-token
